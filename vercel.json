{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["api/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(index\\.html)",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(dashboard\\.html)",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/(app\\.js)",
      "dest": "/frontend/app.js"
    },
    {
      "src": "/(logo\\.svg)",
      "dest": "/frontend/logo.svg"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/oppora_assets/(.*)",
      "dest": "/frontend/oppora_assets/$1"
    },
    {
      "src": "/(dashboard|leads|campaigns|mailboxes|ideal-customer|lists|ai-workflow|finder|email-accounts|unibox|linkedin|crm|reports|settings|integrations|setup-guide)(.*)",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
