{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(index\\.html)",
      "dest": "/index.html"
    },
    {
      "src": "/(dashboard\\.html)",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(app\\.js)",
      "dest": "/app.js"
    },
    {
      "src": "/(logo\\.svg)",
      "dest": "/logo.svg"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(dashboard|leads|campaigns|mailboxes|ideal-customer|lists|ai-workflow|finder|email-accounts|unibox|linkedin|crm|reports|settings|integrations|setup-guide)(.*)",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
